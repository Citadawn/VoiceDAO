    <!-- Debug mode info -->
    <string name="test_mode_info_title" tools:ignore="MissingTranslation">Debug Mode Instructions</string>
    <string name="test_mode_info_content" tools:ignore="MissingTranslation"><![CDATA[
        Debug Mode lets developers enable specific diagnostic and debugging features.<br/><br/>
        <b>Usage:</b><br/>
        • Tap the app name in the top-left corner 7 times to open the debug panel<br/>
        • Select one or more debug items by checking the checkboxes<br/>
        • The Enable button shows the number of selected items<br/>
        • Tap Enable to enter debug mode; while active, tap the app name 7 times again to reopen the debug panel<br/>
        • The interface changes to indicate debug mode is active<br/><br/>
        <b>Debug features:</b><br/>
        • Simulate specific scenarios or output diagnostic information<br/>
        • Tap <b>Exit Debug Mode</b> in the top-right overflow menu (⋮) to leave debug mode<br/>
        • Debug mode does not affect normal app functionality
    ]]></string>

