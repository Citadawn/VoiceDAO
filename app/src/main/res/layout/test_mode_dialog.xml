<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/debugPanelRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_debug_panel_shell"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_debug_panel_header"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="@dimen/dp_16"
        android:paddingTop="@dimen/dp_16"
        android:paddingEnd="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="@dimen/dp_4"
                android:layout_height="@dimen/dp_28"
                android:layout_marginEnd="@dimen/dp_12"
                android:background="@color/accent_warning" />

            <TextView
                android:id="@+id/tvTestModeDialogTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_mode_dialog_title"
                android:textColor="@color/accent_warning"
                android:textSize="@dimen/sp_20"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivTestModeInfo"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_8"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/test_mode_info_title"
                android:focusable="true"
                android:src="@drawable/ic_info"
                app:tint="@color/accent_warning" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTestModeDialogSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_8"
            android:text="@string/test_mode_dialog_subtitle"
            android:textColor="@color/gray_666"
            android:textSize="@dimen/sp_13" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/dp_16"
        android:paddingTop="@dimen/dp_8"
        android:paddingEnd="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_4">

        <TextView
            android:id="@+id/btnExpandAllDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_debug_panel_text_action"
            android:clickable="true"
            android:contentDescription="@string/test_mode_btn_expand_all_desc"
            android:drawableStart="@drawable/ic_debug_expand"
            android:drawablePadding="@dimen/dp_4"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="@dimen/dp_36"
            android:paddingStart="@dimen/dp_8"
            android:paddingTop="@dimen/dp_8"
            android:paddingEnd="@dimen/dp_8"
            android:paddingBottom="@dimen/dp_8"
            android:text="@string/test_mode_btn_expand_all_short"
            android:textColor="@color/accent_warning"
            android:textSize="@dimen/sp_13"
            android:textStyle="bold"
            tools:ignore="RtlSymmetry" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnCollapseAllDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_debug_panel_text_action"
            android:clickable="true"
            android:contentDescription="@string/test_mode_btn_collapse_all_desc"
            android:drawableStart="@drawable/ic_debug_collapse"
            android:drawablePadding="@dimen/dp_4"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="@dimen/dp_36"
            android:paddingStart="@dimen/dp_8"
            android:paddingTop="@dimen/dp_8"
            android:paddingEnd="@dimen/dp_8"
            android:paddingBottom="@dimen/dp_8"
            android:text="@string/test_mode_btn_collapse_all_short"
            android:textColor="@color/accent_warning"
            android:textSize="@dimen/sp_13"
            android:textStyle="bold"
            tools:ignore="RtlSymmetry" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/dp_12"
        android:layout_marginEnd="@dimen/dp_12"
        android:layout_weight="1"
        android:background="@drawable/bg_debug_panel_content_well"
        android:minHeight="@dimen/dp_120"
        android:padding="@dimen/dp_8">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTestCases"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true"
            android:overScrollMode="ifContentScrolls"
            android:paddingEnd="@dimen/dp_10"
            android:scrollbarStyle="outsideInset"
            android:scrollbarThumbVertical="@drawable/bg_debug_panel_scrollbar_thumb"
            android:scrollbars="vertical" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginTop="@dimen/dp_12"
        android:layout_marginEnd="@dimen/dp_16"
        android:background="@color/accent_warning_overlay_25" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/dp_16">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_48"
            android:layout_marginEnd="@dimen/dp_8"
            android:layout_weight="1"
            android:background="@drawable/bg_debug_panel_btn_outline"
            android:stateListAnimator="@animator/btn_scale_animator"
            android:text="@string/test_mode_btn_cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/sp_16" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartTest"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_48"
            android:layout_marginStart="@dimen/dp_8"
            android:layout_weight="1"
            android:background="@drawable/btn_debug_mode_bg"
            android:stateListAnimator="@animator/btn_scale_animator"
            android:text="@string/test_mode_btn_start"
            android:textAllCaps="false"
            android:textColor="@color/pure_white"
            android:textSize="@dimen/sp_16" />
    </LinearLayout>
</LinearLayout>
