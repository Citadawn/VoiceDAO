    <!-- 发音人信息 -->
    <string name="voice_info_title" tools:ignore="MissingTranslation">Voice Instructions</string>
    <string name="voice_info_content" tools:ignore="MissingTranslation"><![CDATA[
        Voice selection allows you to choose different speakers for text-to-speech.<br/><br/>
        <b>Selection Process:</b><br/>
        • First select a language, then choose a voice<br/>
        • Each language has one or more available voices<br/>
        • Only one voice per language is marked as "(Default)"<br/><br/>
        <b>Voice Features:</b><br/>
        • Voice features are displayed below the name in [brackets], but not all voices have features<br/>
        • Features show voice capabilities and characteristics<br/>
        • Deep background indicates the currently selected voice
    ]]></string>

